# RestoBoom Audit Generator — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos clés API

# Clé API Google Places (obligatoire pour la collecte de données)
GOOGLE_PLACES_API_KEY=

# Clé SerpAPI (optionnel, pour données enrichies: avis, posts, FAQ)
SERPAPI_KEY=

# Clé API Anthropic Claude (pour l'analyse IA et les recommandations)
ANTHROPIC_API_KEY=
